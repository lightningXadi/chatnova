{
  "name": "chatbased",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c auto \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build": "npm --workspace apps/web run build && npm --workspace apps/server run build",
    "lint": "npm --workspace apps/web run lint && npm --workspace apps/server run lint",
    "start": "npm --workspace apps/server run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
